<svg width="100%" viewBox="0 0 690 390" role="img" xmlns="http://www.w3.org/2000/svg" style="">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Arham Saifar portfolio LinkedIn thumbnail v2</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Refined dark portfolio thumbnail for LinkedIn featured section</desc>

  <defs>
    <pattern id="g" width="48" height="48" patternUnits="userSpaceOnUse">
      <path d="M 48 0 L 0 0 0 48" fill="none" stroke="rgba(255,255,255,0.035)" stroke-width="0.5"/>
    </pattern>
    <radialGradient id="glow" cx="20%" cy="50%" r="60%">
      <stop offset="0%" stop-color="#c8ff00" stop-opacity="0.07"/>
      <stop offset="100%" stop-color="#080808" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="namegrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#f0ede8"/>
      <stop offset="100%" stop-color="rgba(240,237,232,0.7)"/>
    </linearGradient>
  </defs>

  <!-- base -->
  <rect width="680" height="380" fill="#080808" style="fill:rgb(8, 8, 8);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect width="680" height="380" fill="url(#g)" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect width="680" height="380" fill="url(#glow)" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- top border accent -->
  <rect x="0" y="0" width="680" height="1.5" fill="#c8ff00" opacity="0.5" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- left vertical rule -->
  <rect x="48" y="0" width="1" height="380" fill="rgba(255,255,255,0.06)" style="fill:rgba(255, 255, 255, 0.06);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- right panel dark -->
  <rect x="440" y="0" width="240" height="380" fill="rgba(0,0,0,0.35)" style="fill:rgba(0, 0, 0, 0.35);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="440" y="0" width="1" height="380" fill="rgba(255,255,255,0.06)" style="fill:rgba(255, 255, 255, 0.06);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- top-left meta -->
  <text x="64" y="52" font-family="'Courier New',monospace" font-size="10" fill="#c8ff00" opacity="0.7" letter-spacing="4" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.7;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:start;dominant-baseline:auto">ARHAM SAIFAR — 2025</text>

  <!-- giant AS monogram background -->
  <text x="44" y="290" font-family="Georgia,serif" font-size="260" font-weight="700" fill="rgba(200,255,0,0.025)" letter-spacing="-16" style="fill:rgba(200, 255, 0, 0.024);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, serif;font-size:260px;font-weight:700;text-anchor:start;dominant-baseline:auto">AS</text>

  <!-- name -->
  <text x="64" y="170" font-family="Georgia,serif" font-size="82" font-weight="700" fill="url(#namegrad)" letter-spacing="-3" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, serif;font-size:82px;font-weight:700;text-anchor:start;dominant-baseline:auto">Arham</text>
  <text x="64" y="248" font-family="Georgia,serif" font-size="82" font-weight="700" fill="rgba(240,237,232,0.15)" letter-spacing="-3" style="fill:rgba(240, 237, 232, 0.15);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, serif;font-size:82px;font-weight:700;text-anchor:start;dominant-baseline:auto">Saifar.</text>

  <!-- horizontal rule under name -->
  <rect x="64" y="264" width="340" height="1" fill="rgba(255,255,255,0.08)" style="fill:rgba(255, 255, 255, 0.08);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="64" y="264" width="80" height="1" fill="#c8ff00" opacity="0.7" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.7;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- role -->
  <text x="64" y="292" font-family="'Courier New',monospace" font-size="12" fill="rgba(240,237,232,0.5)" letter-spacing="2" style="fill:rgba(240, 237, 232, 0.5);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:12px;font-weight:400;text-anchor:start;dominant-baseline:auto">AI &amp; BACKEND ENGINEER</text>

  <!-- slogan -->
  <rect x="64" y="318" width="170" height="24" fill="#c8ff00" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="74" y="334" font-family="'Courier New',monospace" font-size="11" font-weight="700" fill="#080808" letter-spacing="2" style="fill:rgb(8, 8, 8);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:700;text-anchor:start;dominant-baseline:auto">BUILT TO IMPRESS.</text>

  <!-- bottom left domain -->
  <text x="64" y="362" font-family="'Courier New',monospace" font-size="10" fill="rgba(240,237,232,0.2)" letter-spacing="2" style="fill:rgba(240, 237, 232, 0.2);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:start;dominant-baseline:auto">arhamsaifar.site</text>

  <!-- RIGHT PANEL content -->
  <!-- label -->
  <text x="460" y="52" font-family="'Courier New',monospace" font-size="9" fill="rgba(200,255,0,0.5)" letter-spacing="3" style="fill:rgba(200, 255, 0, 0.5);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:9px;font-weight:400;text-anchor:start;dominant-baseline:auto">STACK_INDEX</text>
  <rect x="460" y="58" width="160" height="0.5" fill="rgba(255,255,255,0.08)" style="fill:rgba(255, 255, 255, 0.08);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- stack items -->
  <text x="460" y="90" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">01  Python</text>
  <text x="460" y="114" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">02  TensorFlow</text>
  <text x="460" y="138" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">03  React</text>
  <text x="460" y="162" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">04  Flask / FastAPI</text>
  <text x="460" y="186" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">05  AWS Bedrock</text>
  <text x="460" y="210" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">06  OpenCV</text>
  <text x="460" y="234" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">07  MongoDB</text>
  <text x="460" y="258" font-family="'Courier New',monospace" font-size="11" fill="rgba(240,237,232,0.55)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.55);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:start;dominant-baseline:auto">08  Docker</text>

  <rect x="460" y="270" width="160" height="0.5" fill="rgba(255,255,255,0.08)" style="fill:rgba(255, 255, 255, 0.08);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- status block -->
  <rect x="460" y="285" width="8" height="8" rx="4" fill="#c8ff00" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="476" y="293" font-family="'Courier New',monospace" font-size="10" fill="rgba(240,237,232,0.5)" letter-spacing="1" style="fill:rgba(240, 237, 232, 0.5);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:start;dominant-baseline:auto">OPEN TO WORK</text>

  <!-- projects count -->
  <text x="460" y="330" font-family="Georgia,serif" font-size="36" font-weight="700" fill="#c8ff00" opacity="0.9" style="fill:rgb(200, 255, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:Georgia, serif;font-size:36px;font-weight:700;text-anchor:start;dominant-baseline:auto">5+</text>
  <text x="460" y="348" font-family="'Courier New',monospace" font-size="9" fill="rgba(240,237,232,0.3)" letter-spacing="2" style="fill:rgba(240, 237, 232, 0.3);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:9px;font-weight:400;text-anchor:start;dominant-baseline:auto">PROJECTS SHIPPED</text>

  <!-- corner bracket top right -->
  <polyline points="652,16 668,16 668,32" fill="none" stroke="#c8ff00" stroke-width="1.5" opacity="0.4" style="fill:none;stroke:rgb(200, 255, 0);color:rgb(255, 255, 255);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- corner bracket bottom left (inner content area) -->
  <polyline points="64,370 48,370 48,356" fill="none" stroke="#c8ff00" stroke-width="1.5" opacity="0.3" style="fill:none;stroke:rgb(200, 255, 0);color:rgb(255, 255, 255);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.3;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- bottom border -->
  <rect x="0" y="378" width="680" height="1.5" fill="rgba(200,255,0,0.15)" style="fill:rgba(200, 255, 0, 0.15);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
</svg>